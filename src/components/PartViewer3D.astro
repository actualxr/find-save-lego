<div id="three-container">
    <div id="loader-status">Select a part to view in 3D</div>
</div>

<style>
  #three-container {
    width: 100%;
    height: 100vh;
    background: radial-gradient(#2c3e50, #000000);
    position: relative;
    overflow: hidden;
  }

  #loader-status {
    position: absolute;
    top: 20px;
    left: 20px;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    padding: 10px 20px;
    border-radius: 5px;
    font-family: sans-serif;
    font-size: 14px;
    pointer-events: none;
    border: 1px solid #444;
    z-index: 10;
  }
</style>

<script>
  import * as THREE from 'three';
  import { LDrawLoader } from 'three/examples/jsm/loaders/LDrawLoader.js';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  let scene, camera, renderer, controls, currentModel;
  let ldrawLoader;

  // The Root URL for the LDraw Library
  const LDRAW_BASE_URL = 'https://raw.githubusercontent.com/gkjohnson/ldraw-parts-library/master/complete/ldraw/';

  function init() {
    const container = document.getElementById('three-container');
    if (!container) return;

    scene = new THREE.Scene();

    camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 1, 10000);
    camera.position.set(400, 400, 400);

    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(container.clientWidth, container.clientHeight);
    container.appendChild(renderer.domElement);

    controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    scene.add(new THREE.AmbientLight(0xffffff, 2));
    const dirLight = new THREE.DirectionalLight(0xffffff, 1.5);
    dirLight.position.set(100, 200, 100);
    scene.add(dirLight);

    // Initialize Loader
    ldrawLoader = new LDrawLoader();
    
    // IMPORTANT: This tells the loader where to find "dependencies" (primitives like studs)
    ldrawLoader.setPartsLibraryPath(LDRAW_BASE_URL);

    window.addEventListener('request-part-render', (e) => {
      const partId = e.detail.partId;
      updateStatus(`Fetching Part ${partId} from Global Library...`);
      loadLegoPart(partId);
    });

    window.addEventListener('resize', () => {
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    });

    animate();
  }

  function loadLegoPart(partId) {
    if (currentModel) scene.remove(currentModel);

    // FIX: We must use the FULL ABSOLUTE URL for the main part load
    // This prevents the browser from looking on your Netlify domain
    const fullPartUrl = `${LDRAW_BASE_URL}parts/${partId}.dat`;

    ldrawLoader.load(fullPartUrl, 
      (group) => {
        setupModel(group);
      },
      undefined,
      (err) => {
        console.warn(`Part ${partId} not found at ${fullPartUrl}. Trying fallback...`);
        handleLoadError(partId);
      }
    );
  }

  function setupModel(group) {
    group.rotation.x = Math.PI; // Correct LDraw orientation

    const box = new THREE.Box3().setFromObject(group);
    const center = box.getCenter(new THREE.Vector3());
    group.position.sub(center);

    currentModel = group;
    scene.add(currentModel);

    // Auto-frame based on part size
    const size = box.getSize(new THREE.Vector3()).length();
    camera.position.set(size * 2, size * 2, size * 2);
    camera.lookAt(0, 0, 0);
    controls.reset();

    updateStatus("Render Successful");
    setTimeout(() => {
        const status = document.getElementById('loader-status');
        if (status) status.style.display = 'none';
    }, 1500);
  }

  function handleLoadError(partId) {
    // Fallback logic for parts with suffixes (like pb01)
    const baseId = partId.split(/[a-z]/i)[0]; 
    
    if (baseId && baseId !== partId) {
      updateStatus(`Trying base model: ${baseId}`);
      const fallbackUrl = `${LDRAW_BASE_URL}parts/${baseId}.dat`;
      ldrawLoader.load(fallbackUrl, setupModel, undefined, () => {
        updateStatus(`Part ${partId} is not in the LDraw library.`);
      });
    } else {
      updateStatus(`Error: Part ${partId} not found.`);
    }
  }

  function updateStatus(text) {
    const status = document.getElementById('loader-status');
    if (status) {
      status.style.display = 'block';
      status.innerText = text;
    }
  }

  function animate() {
    requestAnimationFrame(animate);
    if (controls) controls.update();
    renderer.render(scene, camera);
  }

  init();
</script>