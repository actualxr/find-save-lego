<div id="three-container"></div>

<style>
  #three-container { width: 100%; height: 100%; min-height: 500px; }
</style>

<script>
  import * as THREE from 'three';
  import { LDrawLoader } from 'three/examples/jsm/loaders/LDrawLoader.js';

  let scene, camera, renderer, currentModel;

  function init() {
    const container = document.getElementById('three-container');
    
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x111111);

    camera = new THREE.PerspectiveCamera(45, container.offsetWidth / container.offsetHeight, 1, 10000);
    camera.position.set(150, 150, 150);

    const light = new THREE.DirectionalLight(0xffffff, 3);
    light.position.set(1, 1, 1);
    scene.add(light);
    scene.add(new THREE.AmbientLight(0xffffff, 0.5));

    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(container.offsetWidth, container.offsetHeight);
    container.appendChild(renderer.domElement);

    const loader = new LDrawLoader();
    // CDN for LEGO Parts
    loader.setPartsLibraryPath('https://cdn.jsdelivr.net/gh/gkjohnson/ldraw-parts-library@master/complete/ldraw/');

    // Listen for the "View 3D" button click from PartList.astro
    window.addEventListener('render-lego-part', (e) => {
      const partId = e.detail.partId;
      
      loader.load(`parts/${partId}.dat`, (group) => {
        if (currentModel) scene.remove(currentModel);
        
        // Re-orient LDraw parts for Three.js
        group.rotation.x = Math.PI; 
        currentModel = group;
        scene.add(currentModel);
      });
    });

    animate();
  }

  function animate() {
    requestAnimationFrame(animate);
    if (currentModel) currentModel.rotation.y += 0.01;
    renderer.render(scene, camera);
  }

  init();
</script>
