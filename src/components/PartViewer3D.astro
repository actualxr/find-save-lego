<div id="three-container">
    <div id="loader-status">Select a part to view in 3D</div>
</div>

<style>
  #three-container {
    width: 100%;
    height: 100vh;
    background: radial-gradient(#2c3e50, #000000);
    position: relative;
    overflow: hidden;
  }

  #loader-status {
    position: absolute;
    top: 20px;
    left: 20px;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    padding: 10px 20px;
    border-radius: 5px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    font-size: 14px;
    pointer-events: none;
    border: 1px solid #444;
    z-index: 10;
  }
</style>

<script>
  import * as THREE from 'three';
  import { LDrawLoader } from 'three/examples/jsm/loaders/LDrawLoader.js';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  let scene, camera, renderer, controls, currentModel;
  let ldrawLoader;

  // This is the "Universal" Mirror. It pulls directly from the official LDraw parts library.
  // We use the 'raw' GitHub URL to get the actual file data.
  const LDRAW_LIBRARY_URL = 'https://raw.githubusercontent.com/gkjohnson/ldraw-parts-library/master/complete/ldraw/';

  function init() {
    const container = document.getElementById('three-container');
    if (!container) return;

    // 1. Scene setup
    scene = new THREE.Scene();

    // 2. Camera setup
    camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 1, 10000);
    camera.position.set(400, 400, 400);

    // 3. Renderer setup
    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(container.clientWidth, container.clientHeight);
    container.appendChild(renderer.domElement);

    // 4. Controls
    controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;

    // 5. Lighting
    const ambientLight = new THREE.AmbientLight(0xffffff, 2);
    scene.add(ambientLight);

    const dirLight = new THREE.DirectionalLight(0xffffff, 1.5);
    dirLight.position.set(100, 200, 100);
    scene.add(dirLight);

    // 6. LDraw Loader Configuration
    ldrawLoader = new LDrawLoader();
    
    // This tells the loader where to find the /parts and /p folders
    ldrawLoader.setPartsLibraryPath(LDRAW_LIBRARY_URL);

    // 7. Event Listener for clicks from PartList.astro
    window.addEventListener('request-part-render', (e) => {
      const partId = e.detail.partId;
      updateStatus(`Loading LEGO Part ${partId}...`);
      loadLegoPart(partId);
    });

    // 8. Handle Window Resize
    window.addEventListener('resize', () => {
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    });

    animate();
  }

  function loadLegoPart(partId) {
    // Clear previous model if it exists
    if (currentModel) {
      scene.remove(currentModel);
    }

    // Attempt to load the specific brick file
    // The loader automatically checks LDRAW_LIBRARY_URL/parts/ID.dat
    ldrawLoader.load(`parts/${partId}.dat`, 
      (group) => {
        setupModel(group);
      },
      undefined,
      (err) => {
        console.warn(`Part ${partId} not found. Trying fallback logic...`);
        handleLoadError(partId);
      }
    );
  }

  function setupModel(group) {
    // Re-orient LDraw parts (they are inverted on the Y axis by default)
    group.rotation.x = Math.PI;

    // Auto-center the part
    const box = new THREE.Box3().setFromObject(group);
    const center = box.getCenter(new THREE.Vector3());
    group.position.sub(center);

    currentModel = group;
    scene.add(currentModel);

    // Auto-frame: Adjust camera to fit the size of the brick
    const size = box.getSize(new THREE.Vector3()).length();
    camera.position.set(size * 2, size * 2, size * 2);
    camera.lookAt(0, 0, 0);
    controls.reset();

    updateStatus("Rendering Complete");
    setTimeout(() => {
        const status = document.getElementById('loader-status');
        if (status) status.style.display = 'none';
    }, 1000);
  }

  function handleLoadError(partId) {
    // Fallback: If it's a printed part (e.g., 3001pb01), strip suffixes and try the base brick
    const baseId = partId.split(/[a-z]/i)[0]; 
    
    if (baseId && baseId !== partId) {
      updateStatus(`Base model fallback: ${baseId}`);
      ldrawLoader.load(`parts/${baseId}.dat`, setupModel, undefined, () => {
        updateStatus(`Part ${partId} not available in 3D library.`);
      });
    } else {
      updateStatus(`Error: Part ${partId} not found.`);
    }
  }

  function updateStatus(text) {
    const status = document.getElementById('loader-status');
    if (status) {
      status.style.display = 'block';
      status.innerText = text;
    }
  }

  function animate() {
    requestAnimationFrame(animate);
    if (controls) controls.update();
    renderer.render(scene, camera);
  }

  // Kick off the initialization
  init();
</script>