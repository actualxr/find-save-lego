<div id="lego-viewport"></div>

<script>
  import * as THREE from 'three';

  const container = document.getElementById('lego-viewport');
  
  // Setup Scene
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });

  renderer.setSize(container.clientWidth, container.clientHeight);
  container.appendChild(renderer.domElement);

  // Create a spinning red block (placeholder for LEGO)
  const geometry = new THREE.BoxGeometry(1.5, 1, 1);
  const material = new THREE.MeshStandardMaterial({ color: 0xff0000 });
  const brick = new THREE.Mesh(geometry, material);
  scene.add(brick);

  // Add Lights
  const light = new THREE.DirectionalLight(0xffffff, 1.5);
  light.position.set(5, 5, 5);
  scene.add(light);
  scene.add(new THREE.AmbientLight(0x404040));

  camera.position.z = 4;

  // Animation Loop
  function animate() {
    requestAnimationFrame(animate);
    brick.rotation.x += 0.01;
    brick.rotation.y += 0.01;
    renderer.render(scene, camera);
  }

  // Handle screen resize
  window.addEventListener('resize', () => {
    renderer.setSize(container.clientWidth, container.clientHeight);
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
  });

  animate();
</script>

<style>
  #lego-viewport {
    width: 100%;
    height: 100%;
    background: radial-gradient(#2c2c2c, #000);
    cursor: grab;
  }
</style>
