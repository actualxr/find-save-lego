<script>
  import * as THREE from 'three';
  import { LDrawLoader } from 'three/examples/jsm/loaders/LDrawLoader.js';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  let scene, camera, renderer, controls, currentModel;
  const container = document.getElementById('three-container');
  const loaderOverlay = document.getElementById('loading-overlay');

  function init() {
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x111111);
    
    camera = new THREE.PerspectiveCamera(45, container.offsetWidth / container.offsetHeight, 1, 10000);
    camera.position.set(200, 200, 200);

    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(container.offsetWidth, container.offsetHeight);
    container.appendChild(renderer.domElement);

    controls = new OrbitControls(camera, renderer.domElement);
    
    scene.add(new THREE.AmbientLight(0xffffff, 2));
    const sun = new THREE.DirectionalLight(0xffffff, 1);
    sun.position.set(10, 10, 10);
    scene.add(sun);

    const loader = new LDrawLoader();
    // CDN for the library
    loader.setPartsLibraryPath('https://cdn.jsdelivr.net/gh/gkjohnson/ldraw-parts-library@master/complete/ldraw/');

    // Listener for the button click
    window.addEventListener('request-part-render', (e) => {
      const partId = e.detail.partId;
      console.log("Attempting to load LEGO Part ID:", partId);
      loadLegoPart(partId, loader);
    });

    animate();
  }

  async function loadLegoPart(partId, loader) {
    loaderOverlay.style.display = 'block';
    loaderOverlay.innerText = `Searching for part ${partId}...`;

    // Try 1: Exact Match (e.g. 3001.dat)
    let fileName = `${partId}.dat`;
    
    loader.load(`parts/${fileName}`, 
      (group) => {
        handleSuccess(group);
      },
      undefined,
      (err) => {
        // Try 2: If it has letters (like 3001pb01), strip them and try the base brick (3001.dat)
        const baseId = partId.match(/^\d+/); // Get just the numbers
        if (baseId && baseId[0] !== partId) {
          console.warn(`Part ${partId} not found, trying base model ${baseId[0]}...`);
          loader.load(`parts/${baseId[0]}.dat`, handleSuccess, undefined, handleFinalError);
        } else {
          handleFinalError(err);
        }
      }
    );
  }

  function handleSuccess(group) {
    if (currentModel) scene.remove(currentModel);
    group.rotation.x = Math.PI; // LDraw orientation fix
    
    // Center the part
    const box = new THREE.Box3().setFromObject(group);
    const center = box.getCenter(new THREE.Vector3());
    group.position.sub(center);

    currentModel = group;
    scene.add(currentModel);
    loaderOverlay.style.display = 'none';
    controls.reset();
  }

  function handleFinalError(err) {
    console.error("LDraw Loader Error:", err);
    loaderOverlay.innerText = "Error: Part not in LDraw Library";
  }

  function animate() {
    requestAnimationFrame(animate);
    controls.update();
    renderer.render(scene, camera);
  }

  init();
</script>