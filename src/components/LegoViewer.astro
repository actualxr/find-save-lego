import * as THREE from 'three';
import { LDrawLoader } from 'three/examples/jsm/loaders/LDrawLoader.js';

let scene, camera, renderer, currentModel;

const container = document.getElementById('lego-container');

function init() {
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0xeeeeee);

    camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 1, 10000);
    camera.position.set(100, 100, 100);

    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(container.clientWidth, container.clientHeight);
    container.appendChild(renderer.domElement);

    const loader = new LDrawLoader();
    
    // Using jsDelivr to proxy the GitHub repo correctly
    loader.setPartsLibraryPath('https://cdn.jsdelivr.net/gh/gkjohnson/ldraw-parts-library@master/complete/ldraw/');

    // Listener for UI events
    window.addEventListener('request-part-render', (e) => {
        const partId = e.detail.partId; // e.g., "3001"
        
        loader.load(`parts/${partId}.dat`, (group) => {
            if (currentModel) scene.remove(currentModel);
            
            // Re-orient the part so it's not upside down (LDraw uses a different Y-axis)
            group.rotation.x = Math.PI; 
            currentModel = group;
            scene.add(currentModel);
        });
    });

    animate();
}

function animate() {
    requestAnimationFrame(animate);
    if (currentModel) currentModel.rotation.y += 0.01;
    renderer.render(scene, camera);
}

init();
