---
import { db, Inventory, eq } from 'astro:db'; // 1. Add the import back

const { setNum = "75192-1" } = Astro.props;
let parts = [];

try {
  // 2. Try to fetch from the DB
  parts = await db.select().from(Inventory).where(eq(Inventory.set_num, setNum));
} catch (e) {
  // 3. Fallback to mock data if the DB is empty or fails during build
  console.log("DB is empty, using temporary mock data");
  parts = [
    { id: 1, part_num: '3001', name: 'Brick 2x4 (Mock)', quantity_found: 0, quantity_needed: 5, image_url: 'https://rebrickable.com/media/parts/elements/300126.jpg' }
  ];
}
---

<div class="part-browser">
  <ul id="inventory-list" style="list-style: none; padding: 0;">
    {parts.map((part) => (
      <li class="part-item" style="display: flex; align-items: center; gap: 10px; background: #2a2a2a; padding: 10px; margin-bottom: 5px; border-radius: 4px;">
        <img src={part.image_url} width="50" alt={part.name} />
        <div style="flex: 1;">
          <div style="font-weight: bold;">{part.name}</div>
          <small>{part.quantity_found} / {part.quantity_needed}</small>
        </div>
        <button class="view-3d-btn" data-part={part.part_num} style="cursor: pointer; padding: 5px 10px;">3D</button>
      </li>
    ))}
  </ul>
</div>

<script>
  document.querySelectorAll('.view-3d-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const partId = btn.getAttribute('data-part');
      console.log("Requesting 3D render for:", partId);
      window.dispatchEvent(new CustomEvent('request-part-render', { 
        detail: { partId } 
      }));
    });
  });
</script>