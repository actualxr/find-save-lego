---
import { db, Inventory, eq } from 'astro:db';

const { setNum = "75192-1" } = Astro.props;
let parts = [];

try {
  // This now fetches the 100 real parts you just seeded!
  parts = await db.select().from(Inventory).where(eq(Inventory.set_num, setNum));
} catch (e) {
  console.error("Database fetch failed:", e);
}
---

<div class="part-browser">
  <ul id="inventory-list" style="list-style: none; padding: 0; margin: 0;">
    {parts.length === 0 ? (
      <li style="padding: 20px; text-align: center; color: #888;">No parts found. Check your database connection.</li>
    ) : (
      parts.map((part) => (
        <li class="part-item">
          <img src={part.image_url} width="40" height="40" alt={part.name} style="border-radius: 4px; background: #eee;" />
          <div class="info">
            <span class="part-name">{part.name}</span>
            <small class="part-qty">{part.quantity_found} / {part.quantity_needed}</small>
          </div>
          <button class="view-3d-btn" data-part={part.part_num}>3D</button>
        </li>
      ))
    )}
  </ul>
</div>

<style>
  .part-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #222;
    padding: 10px;
    margin-bottom: 8px;
    border-radius: 6px;
    border: 1px solid #333;
  }
  .info { flex: 1; display: flex; flex-direction: column; }
  .part-name { font-size: 0.9rem; color: #fff; font-weight: 500; }
  .part-qty { color: #aaa; font-size: 0.75rem; }
  .view-3d-btn {
    background: #e53935;
    color: white;
    border: none;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 0.75rem;
    cursor: pointer;
    font-weight: bold;
  }
  .view-3d-btn:hover { background: #ff5252; }
</style>

<script>
  document.querySelectorAll('.view-3d-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const partId = btn.getAttribute('data-part');
      // Tell PartViewer3D.astro to render this specific LEGO part
      window.dispatchEvent(new CustomEvent('request-part-render', { 
        detail: { partId } 
      }));
    });
  });
</script>